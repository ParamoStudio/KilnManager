{
  "name": "kiln-manager",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Páramo Kiln Manager — visual kiln load planner & fair cost distribution (internal studio tool).",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dev:web": "vite",
    "build:web": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:svelte": "svelte-check --tsconfig ./tsconfig.json",
    "check:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck": "npm run check:node && npm run check:svelte"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@types/node": "^22.10.2",
    "electron": "^33.2.1",
    "electron-vite": "^2.3.0",
    "svelte": "^5.15.0",
    "svelte-check": "^4.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
